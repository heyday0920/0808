<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions for image loading -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar"
        tools:targetApi="31">

        <activity android:name=".SplashActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity android:name=".LoginActivity" />
        <activity android:name=".TopActivity" />
        <activity android:name=".CalendarActivity" />
        <activity android:name=".FilterActivity" />
        <activity android:name=".PractitionerListActivity" />
        <activity android:name=".PractitionerDetailActivity" />
        <activity android:name=".PlanDetailActivity" />
        <activity android:name=".SignupActivity" />
        <activity android:name=".UserInfoActivity" />
        <activity android:name=".GenderSelectionActivity" />
        <activity android:name=".BirthdayInputActivity" />
        <activity android:name=".AreaSelectionActivity" />
        <activity android:name=".MenuSelectionActivity" />
        <activity android:name=".MenuFilterActivity" />
        <activity android:name=".DateTimeSelectionActivity" />
        <activity android:name=".StoreDetailActivity" />
        <activity android:name=".MessageActivity" />

    </application>

</manifest>