<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Light Theme - Material Design 3 -->
    <style name="Theme.Beauvidual" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
        
        <!-- Tertiary brand color. -->
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>
        
        <!-- Error colors -->
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_light_outline</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/md_theme_light_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/md_theme_light_surface</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- Window settings -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
    
    <!-- Custom Button Styles -->
    <style name="Widget.Beauvidual.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="Widget.Beauvidual.Button.Primary" parent="Widget.Beauvidual.Button">
        <item name="backgroundTint">@color/md_theme_light_primary</item>
        <item name="android:textColor">@color/md_theme_light_onPrimary</item>
    </style>
    
    <style name="Widget.Beauvidual.Button.Secondary" parent="Widget.Beauvidual.Button">
        <item name="backgroundTint">@color/md_theme_light_secondaryContainer</item>
        <item name="android:textColor">@color/md_theme_light_onSecondaryContainer</item>
    </style>
    
    <style name="Widget.Beauvidual.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textSize">16sp</item>
        <item name="strokeColor">@color/md_theme_light_outline</item>
        <item name="android:textColor">@color/md_theme_light_primary</item>
    </style>
    
    <!-- Card Styles -->
    <style name="Widget.Beauvidual.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">8dp</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardBackgroundColor">@color/md_theme_light_surface</item>
        <item name="android:layout_margin">8dp</item>
    </style>
    
    <!-- Text Input Styles -->
    <style name="Widget.Beauvidual.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/md_theme_light_primary</item>
        <item name="hintTextColor">@color/md_theme_light_onSurfaceVariant</item>
    </style>
    
    <!-- Typography -->
    <style name="TextAppearance.Beauvidual.Headline" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/md_theme_light_onBackground</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.Beauvidual.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/md_theme_light_onSurface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.Beauvidual.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/md_theme_light_onSurface</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <!-- Fab Style -->
    <style name="Widget.Beauvidual.FloatingActionButton" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/beauty_gradient_start</item>
        <item name="tint">@color/white</item>
        <item name="elevation">12dp</item>
    </style>
    
    <!-- Calendar View Custom Style -->
    <style name="CalendarViewCustom" parent="android:Widget.CalendarView">
        <item name="android:selectedWeekBackgroundColor">@color/md_theme_light_primaryContainer</item>
        <item name="android:focusedMonthDateColor">@color/md_theme_light_primary</item>
        <item name="android:unfocusedMonthDateColor">@color/md_theme_light_onSurfaceVariant</item>
        <item name="android:weekSeparatorLineColor">@color/md_theme_light_outline</item>
        <item name="android:weekNumberColor">@color/md_theme_light_onSurfaceVariant</item>
    </style>
    
</resources>