<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white"
    android:padding="24dp">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp">

        <!-- App Logo/Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Beauvidual"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary_purple"
            android:layout_gravity="center"
            android:fontFamily="serif"
            android:layout_marginBottom="16dp" />

        <!-- Progress Indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:orientation="horizontal"
            android:background="@color/text_primary">

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:background="@color/primary_purple" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/text_primary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Prompt Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="性別を教えてください"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp" />

    <!-- Gender Selection Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="24dp"
        android:elevation="2dp"
        android:layout_marginBottom="24dp">

        <!-- Section Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="性別"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Gender Options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Female Option -->
            <Button
                android:id="@+id/femaleButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="女性"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:background="@drawable/gender_selected_background"
                android:layout_marginBottom="12dp"
                android:elevation="0dp"/>

            <!-- Male Option -->
            <Button
                android:id="@+id/maleButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="男性"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:background="@drawable/gender_unselected_background"
                android:layout_marginBottom="12dp"
                android:elevation="0dp"/>

            <!-- Other Option -->
            <Button
                android:id="@+id/otherButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="その他"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:background="@drawable/gender_unselected_background"
                android:elevation="0dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Information Text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="設定していただくと"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="あなたによりマッチしたサロン情報をお届けできます"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"/>

    </LinearLayout>

    <!-- Next Button -->
    <Button
        android:id="@+id/nextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="次へ"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_primary"
        android:elevation="0dp"
        android:layout_gravity="center" />

</LinearLayout> 