<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white"
    android:padding="24dp">

    <!-- Spacer to push content to center -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- App Logo/Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Beauvidual"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/primary_purple"
        android:layout_gravity="center"
        android:fontFamily="serif"
        android:layout_marginBottom="48dp" />

    <!-- Account Registration Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="アカウント登録"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp" />

    <!-- Sign Up Options -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp">

        <!-- Apple Sign Up Button -->
        <Button
            android:id="@+id/appleSignupButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Appleでサインアップ"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/button_black_background"
            android:layout_marginBottom="16dp"
            android:elevation="0dp"/>

        <!-- LINE Sign Up Button -->
        <Button
            android:id="@+id/lineSignupButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="LINEでサインアップ"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/button_green_background"
            android:layout_marginBottom="16dp"
            android:elevation="0dp"/>

        <!-- Email Sign Up Button -->
        <Button
            android:id="@+id/emailSignupButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="メールアドレスでサインアップ"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/button_outline_background"
            android:elevation="0dp"/>

    </LinearLayout>

    <!-- Help Link -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/helpLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ヘルプ・よくある質問"
            android:textColor="@color/primary_purple"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- Spacer to balance layout -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout> 