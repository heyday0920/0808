<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 施術者情報・チャット -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:background="@drawable/practitioner_info_bg"
            android:padding="16dp"
            android:layout_marginBottom="20dp">
            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/circle_background"
                android:layout_marginEnd="16dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:text="田中 美咲"
                    android:textColor="#222"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="エステティシャン"
                    android:textColor="#666"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- プロフィール詳細 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/profile_card_bg"
            android:padding="20dp"
            android:layout_margin="8dp">
            <TextView
                android:text="プロフィール"
                android:textStyle="bold"
                android:textColor="#222222"
                android:textSize="18sp"
                android:layout_marginBottom="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <!-- 基本情報 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <TextView
                    android:text="基本情報"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:text="名前："
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="Emma myers"
                        android:textColor="#222222"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:text="資格："
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="認定エステティシャン"
                        android:textColor="#222222"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:text="経験："
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="5年"
                        android:textColor="#222222"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
            <!-- 得意分野 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <TextView
                    android:text="得意分野"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:text="#フェイシャルエステ"
                        android:textColor="#7C3AED"
                        android:background="@drawable/tag_background"
                        android:padding="6dp"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="#ボディケア"
                        android:textColor="#7C3AED"
                        android:background="@drawable/tag_background"
                        android:padding="6dp"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:text="#リラクゼーション"
                        android:textColor="#7C3AED"
                        android:background="@drawable/tag_background"
                        android:padding="6dp"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="#アロマセラピー"
                        android:textColor="#7C3AED"
                        android:background="@drawable/tag_background"
                        android:padding="6dp"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
            <!-- 自己紹介 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:text="自己紹介"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="お客様一人ひとりに寄り添った施術を心がけています。リラックスできる空間で、心身ともに癒しの時間をお過ごしいただけます。豊富な経験と確かな技術で、お客様の美と健康をサポートいたします。"
                    android:textColor="#222222"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView> 