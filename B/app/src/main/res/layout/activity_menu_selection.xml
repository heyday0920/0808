<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white"
    android:padding="24dp">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp">

        <!-- App Logo/Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Beauvidual"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary_purple"
            android:layout_gravity="center"
            android:fontFamily="serif"
            android:layout_marginBottom="16dp" />

        <!-- Progress Indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:orientation="horizontal"
            android:background="@color/text_primary">

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="5"
                android:background="@color/primary_purple" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0"
                android:background="@color/text_primary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Menu Selection Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="24dp"
        android:elevation="2dp"
        android:layout_marginBottom="32dp">

        <!-- Section Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="興味のあるメニュー"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Menu Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:useDefaultMargins="true">

            <!-- Row 1 -->
            <Button
                android:id="@+id/relaxButton"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_column="0"
                android:text="リラク"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/menu_unselected_background"
                android:elevation="0dp"/>

            <Button
                android:id="@+id/estheticButton"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_column="1"
                android:text="エステ"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/menu_unselected_background"
                android:elevation="0dp"/>

            <Button
                android:id="@+id/nailButton"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_column="2"
                android:text="ネイル"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/menu_unselected_background"
                android:elevation="0dp"/>

            <!-- Row 2 -->
            <Button
                android:id="@+id/eyelashButton"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_column="0"
                android:layout_row="1"
                android:text="まつげ"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/menu_unselected_background"
                android:elevation="0dp"/>

            <Button
                android:id="@+id/hairRemovalButton"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_column="1"
                android:layout_row="1"
                android:text="脱毛"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/menu_unselected_background"
                android:elevation="0dp"/>

            <Button
                android:id="@+id/massageButton"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_column="2"
                android:layout_row="1"
                android:text="マッサージ"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/menu_selected_background"
                android:elevation="0dp"/>

        </GridLayout>

    </LinearLayout>

    <!-- Next Button -->
    <Button
        android:id="@+id/nextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="次へ"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_primary"
        android:elevation="0dp"
        android:layout_gravity="center" />

</LinearLayout> 