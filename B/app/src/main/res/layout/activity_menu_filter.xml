<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/background_white"
        android:elevation="1dp">

        <!-- Close Button -->
        <ImageView
            android:id="@+id/closeButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/circle_background"
            android:padding="8dp"
            android:tint="@color/text_primary"
            android:clickable="true"
            android:focusable="true" />

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="メニュー・詳細条件"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Selected Conditions Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="選択中の条件"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Featured Keywords Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="注目のキーワード"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/keywordInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="キーワードを入力"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/bg_search_box"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp" />

            <!-- Price Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="料金"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/priceRangeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5,000円 - 料金上限なし"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Price Slider -->
            <SeekBar
                android:id="@+id/priceSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="20"
                android:progressTint="@color/primary_purple"
                android:thumbTint="@color/primary_purple"
                android:layout_marginBottom="24dp" />

            <!-- Hair Removal Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="脱毛"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@color/primary_purple_light"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <CheckBox
                        android:id="@+id/hair_removal_full_body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="全身脱毛"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:checked="true"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/hair_removal_partial"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="部分脱毛"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/hair_removal_shr"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="SHR脱毛"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/hair_removal_ipl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="IPL脱毛"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/hair_removal_ssc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="S.S.C脱毛"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/hair_removal_medical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="医療脱毛"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                </GridLayout>

            </LinearLayout>

            <!-- Body Slimming Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="痩身"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@color/primary_purple_light"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <CheckBox
                        android:id="@+id/slimming_massage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="痩身マッサージ"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/slimming_ems"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="EMS・電気刺激"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/slimming_indiba"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="インディバ"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/slimming_hifu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="ハイフ(HIFU)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/slimming_cellulite"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="セルライトクラッシュ"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:checked="true"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/slimming_cooling"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="冷却冷却"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/slimming_cavitation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="キャビテーション"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/slimming_radio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="ラジオ波"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                </GridLayout>

            </LinearLayout>

            <!-- Facial Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="フェイシャル"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@color/primary_purple_light"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <CheckBox
                        android:id="@+id/facial_esthetic"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="フェイシャルエステ"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/facial_peeling"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="ピーリング"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/facial_whitening"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="美白"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/facial_pore"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="毛穴洗浄"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/facial_lift"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="リフトアップマッサージ"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:checked="true"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/facial_small_face"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="小顔マッサージ"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/facial_beauty_hair"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="美肌脱毛"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                </GridLayout>

            </LinearLayout>

            <!-- Nail, Eyelash, Eyebrow Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ネイル・まつげ・眉"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@color/primary_purple_light"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <CheckBox
                        android:id="@+id/nail_gel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="ジェルネイル"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/nail_sculpt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="スカルプネイル"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/nail_eyelash_ext"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="マツエク"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/nail_eyelash_perm"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="マツパ"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/nail_eyebrow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="アイブロウ"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:checked="true"
                        android:buttonTint="@color/primary_purple" />

                </GridLayout>

            </LinearLayout>

            <!-- Relaxation Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="リラク"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@color/primary_purple_light"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <CheckBox
                        android:id="@+id/relax_maternity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="マタニティマッサージ"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/relax_meal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="食事カウンセリング"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/relax_dna"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="DNA美容解析"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/relax_pair"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="ペア施術"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/relax_personal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="パーソナルトレーニング"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:checked="true"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/relax_kids"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="キッズ脱毛/お子様脱毛"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                    <CheckBox
                        android:id="@+id/relax_mens"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="メンズエステ対応"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:buttonTint="@color/primary_purple" />

                </GridLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Footer Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/background_white"
        android:elevation="2dp">

        <Button
            android:id="@+id/clearButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="クリア"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:background="@drawable/button_outline_background"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/doneButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="完了 (5件)"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:background="@drawable/bg_button_primary"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout> 