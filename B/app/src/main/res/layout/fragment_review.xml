<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 施術者情報・チャット -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:background="@drawable/practitioner_info_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">
            
            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:background="@drawable/circle_background"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"/>
            
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:text="Emma myers(リララ)"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#222222"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="資格取得(認定)エステ"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:text="★★★★☆"
                        android:textColor="#F7B801"
                        android:textSize="14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text=" 4.0 (403)"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:layout_marginStart="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <TextView
                    android:text="JR新宿南口徒歩5分"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            
            <ImageButton
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/chat_button_bg"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#7C3AED"
                android:contentDescription="チャットで相談する"/>
        </LinearLayout>

        <!-- レビュータイトル・平均評価 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">
            <TextView
                android:text="レビュー（403）"
                android:textColor="#222222"
                android:textStyle="bold"
                android:textSize="20sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:text="★4.0 お客様の声から"
                android:textColor="#7C3AED"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- イメージ付きレビュー -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="イメージ付きレビュー"
                android:textColor="#888888"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="12dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"
                    android:background="@drawable/rounded_image_bg"
                    android:layout_marginEnd="8dp"/>
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"
                    android:background="@drawable/rounded_image_bg"
                    android:layout_marginEnd="8dp"/>
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"
                    android:background="@drawable/rounded_image_bg"/>
            </LinearLayout>
        </LinearLayout>

        <!-- レビュー詳細カード -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/review_card_bg"
            android:padding="20dp"
            android:layout_margin="8dp">

            <!-- 総合評価 -->
            <TextView
                android:text="総合評価"
                android:textStyle="bold"
                android:textColor="#222222"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView 
                    android:text="★★★★★" 
                    android:textColor="#FFD700" 
                    android:textSize="18sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text=" 5.0"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            
            <!-- 各項目点数 -->
            <LinearLayout 
                android:orientation="horizontal" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">
                <TextView android:text="接客 4/5  " android:textColor="#666666" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="技術 4/5  " android:textColor="#666666" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="料金 4/5  " android:textColor="#666666" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="雰囲気 4/5" android:textColor="#666666" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            
            <!-- タグ・コース名・金額 -->
            <LinearLayout 
                android:orientation="horizontal" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:layout_marginTop="16dp">
                <TextView 
                    android:text="#フェイシャルエステ" 
                    android:textColor="#7C3AED" 
                    android:background="@drawable/tag_background" 
                    android:padding="6dp"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView 
                    android:text="  クイックボディケア  " 
                    android:textColor="#222222" 
                    android:padding="6dp"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView 
                    android:text="  ￥3,300" 
                    android:textColor="#222222" 
                    android:padding="6dp"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            
            <!-- レビュアー名・アイコン -->
            <LinearLayout 
                android:orientation="horizontal" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">
                <ImageView 
                    android:layout_width="32dp" 
                    android:layout_height="32dp" 
                    android:src="@android:drawable/ic_menu_myplaces" 
                    android:background="@drawable/circle_background"/>
                <TextView 
                    android:text="shitsurei" 
                    android:textColor="#222222" 
                    android:layout_marginStart="12dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView 
                    android:text="レポート作成" 
                    android:textColor="#888888" 
                    android:background="@drawable/report_badge_bg" 
                    android:padding="4dp" 
                    android:layout_marginStart="12dp"
                    android:textSize="10sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            
            <!-- レビュー本文 -->
            <TextView
                android:text="体験中は常に気配りを感じました。リフレッシュしたくて初めてこちらにお世話になりました。最初は緊張していましたが、スタッフの方々も丁寧でした。施術でフェイシャルの効果が実感でき、肌が明るくなった気がします。施術後のアドバイスも的確で、家でも続けてみようと思いました。施設は清潔感があり、雰囲気も落ち着いていて安心感がありました。効果が持続することを期待しています。" 
                android:textColor="#222222"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:paddingTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView> 