<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:padding="16dp"
    android:elevation="2dp">

    <!-- Top Tags Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="保有資格"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/practitionerTag1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AEA認定"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_button_primary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/practitionerTag2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="日本エステティック協会認定"
            android:textColor="@color/primary_purple"
            android:textSize="12sp"
            android:background="@drawable/tag_background"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"/>

    </LinearLayout>

    <!-- Profile and Rating Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- Circular Profile Image -->
        <ImageView
            android:id="@+id/practitionerImage"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_background"
            android:src="@color/background_card"
            android:layout_marginEnd="12dp"/>

        <!-- Name and Rating -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Star Rating -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★★★★"
                    android:textColor="@color/star_active"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/practitionerRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 4.0"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ("
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/practitionerReviewCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="403"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=")"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Name -->
            <TextView
                android:id="@+id/practitionerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emma myers(リラク 新宿東横店内)"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Course Images Horizontal Scroll -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/practitionerCourseImage1"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_image_bg"
                android:src="@color/background_card"/>

            <ImageView
                android:id="@+id/practitionerCourseImage2"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_image_bg"
                android:src="@color/background_card"/>

            <ImageView
                android:id="@+id/practitionerCourseImage3"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_image_bg"
                android:src="@color/background_card"/>

            <ImageView
                android:id="@+id/practitionerCourseImage4"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_image_bg"
                android:src="@color/background_card"/>

            <ImageView
                android:id="@+id/practitionerCourseImage5"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_image_bg"
                android:src="@color/background_card"/>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Service Details and More Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <!-- Service Icon -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_spa"
            android:tint="@color/primary_purple"
            android:layout_marginEnd="8dp"/>

        <!-- Service Name and Price -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/practitionerPlan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ラグジュアリーフェイスエステ 60分"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/practitionerPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8900円"
                android:textColor="@color/primary_purple"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- More Button -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="もっと見る"
            android:textColor="@color/primary_purple"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Review Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="レビュー("
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="403"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=")"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- Review Text -->
    <TextView
        android:id="@+id/practitionerReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="技術も高く丁寧な施術をしていただきました。リラックスもでき大変良い時間エステを楽しむことしました。清潔感のあるお部屋に好感を持てました。スタッフの方もとても優しかったです。・・・"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp"/>

</LinearLayout> 