<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white"
    android:padding="24dp">

    <!-- Spacer to push content to center -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- App Logo/Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Beauvidual"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/primary_purple"
        android:layout_gravity="center"
        android:fontFamily="serif"
        android:layout_marginBottom="48dp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp">

        <!-- Start Beauvidual Button -->
        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Beauvidualを始める"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:layout_marginBottom="16dp"
            android:elevation="0dp"/>

        <!-- Login Button -->
        <Button
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="引き継ぎ/ログイン"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/button_outline_background"
            android:elevation="0dp"/>

    </LinearLayout>

    <!-- Footer Information -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Divider Line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_light"
            android:layout_marginBottom="16dp"/>

        <!-- Terms and Privacy Links -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="利用規約"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/privacyPolicyLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="プライバシーポリシー"
                android:textColor="@color/primary_purple"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/pointsGuidelineLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ポイントガイドライン"
                android:textColor="@color/primary_purple"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:padding="4dp"/>

        </LinearLayout>

        <!-- Agreement Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="に同意した方のみが利用できます"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- Spacer to balance layout -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout> 